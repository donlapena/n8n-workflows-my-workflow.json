    {"parameters":{"operation":"pdf","options":{"joinPages":true}},"id":"4f39cb3d-4c3f-46d4-a1f8-83c619987382","name":"Extract Transcript PDF","type":"n8n-nodes-base.extractFromFile","typeVersion":1.1,"position":[576,400]},
    {"parameters":{"promptType":"define","text":"=Analyze the following transcript and extract:\n1. All science subjects (Biology, Chemistry, Physics, etc.) and math subjects\n2. Calculate the GWA for science and math subjects only\n3. Extract the overall GWA\n4. Determine if overall GWA is 85 or higher\n\nTranscript:\n{{ $json.text }}","hasOutputParser":true,"options":{"systemMessage":"You are an academic records analyst for USTP College of Medicine. Extract grades from transcripts and calculate weighted averages accurately. Return structured data in the exact format specified."}},"id":"b6106374-2fca-43ae-905e-d9d50c9f15b9","name":"Analyze Academic Records","type":"@n8n/n8n-nodes-langchain.agent","typeVersion":3.1,"position":[912,400]},
    {"parameters":{"jsonSchemaExample":"{\"scienceMathGWA\":87.5,\"scienceMathSubjects\":[\"Biology 101: 90%\",\"Chemistry 101: 88%\",\"Physics 101: 85%\",\"Mathematics 101: 88%\"],\"overallGWA\":88,\"meetsGWARequirement\":true}"},"id":"4f824ac4-0b97-4dd3-a5e1-bd2a234496f8","name":"Grading Output Parser","type":"@n8n/n8n-nodes-langchain.outputParserStructured","typeVersion":1.3,"position":[1152,576]},
    {"parameters":{"mode":"runOnceForEachItem","jsCode":"const triggerData = $(\"Google Sheets Trigger\").item.json;\nconst academicData = $json.output;\n\nconst nmatScore = parseFloat(triggerData.NMAT);\nconst overallGWA = academicData.overallGWA;\nconst scienceMathGWA = academicData.scienceMathGWA;\n\nconst meetsNMAT = nmatScore >= 85;\nconst meetsGWA = overallGWA >= 85;\nconst meetsScienceMathGWA = scienceMathGWA >= 85;\n\nconst isQualified = meetsNMAT && meetsGWA && meetsScienceMathGWA;\n\nreturn {\n  fullName: triggerData[\"Full Name\"],\n  email: triggerData.Email,\n  nmatScore: nmatScore,\n  overallGWA: overallGWA,\n  scienceMathGWA: scienceMathGWA,\n  scienceMathSubjects: academicData.scienceMathSubjects,\n  meetsNMAT: meetsNMAT,\n  meetsGWA: meetsGWA,\n  meetsScienceMathGWA: meetsScienceMathGWA,\n  isQualified: isQualified,\n  status: isQualified ? \"For Interview\" : \"Rejected\",\n  evaluationDate: new Date().toISOString()\n};"},"id":"23ff8f8c-0411-40cf-b2b8-037c6472f82f","name":"Check Admission Requirements","type":"n8n-nodes-base.code","typeVersion":2,"position":[1360,400]},
    {"parameters":{"conditions":{"combinator":"and","options":{"caseSensitive":true,"leftValue":"","typeValidation":"strict","version":1},"conditions":[{"leftValue":"={{ $json.isQualified }}","rightValue":true,"operator":{"type":"boolean","operation":"true"}}]},"options":{}},"id":"6eb02b42-e826-4911-88ea-438d029a4738","name":"Check if Qualified","type":"n8n-nodes-base.if","typeVersion":2.3,"position":[1808,400]},
    {"parameters":{"calendar":{"__rl":true,"value":"ma.edonnajanelapena@gmail.com","mode":"list","cachedResultName":"ma.edonnajanelapena@gmail.com"},"start":"={{ $now.plus(7, \"days\").set({ hour: 9, minute: 0 }).toISO() }}","end":"={{ $now.plus(7, \"days\").set({ hour: 10, minute: 0 }).toISO() }}","additionalFields":{"attendees":["={{ $json.email }}"],"description":"=Interview for USTP College of Medicine admission.\n\nApplicant: {{ $json.fullName }}\nEmail: {{ $json.email }}\nNMAT Score: {{ $json.nmatScore }}\nOverall GWA: {{ $json.overallGWA }}\nScience/Math GWA: {{ $json.scienceMathGWA }}","location":"USTP College of Medicine, Cagayan de Oro City","summary":"=Medical School Interview - {{ $json.fullName }}"}},"id":"6f6a3cf8-49aa-4a68-9773-0fd91fcb44d8","name":"Schedule Interview","type":"n8n-nodes-base.googleCalendar","typeVersion":1.3,"position":[2032,304]},
    {"parameters":{"sendTo":"={{ $(\"Check Admission Requirements\").item.json.email }}","subject":"Congratulations! USTP College of Medicine - Interview Invitation","message":"=Dear {{ $(\"Check Admission Requirements\").item.json.fullName }},\n\n<p>Congratulations! We are pleased to inform you that you have passed the initial screening for admission to the USTP College of Medicine.</p>\n\n<p><strong>Your Application Summary:</strong></p>\n<ul>\n<li>NMAT Score: {{ $(\"Check Admission Requirements\").item.json.nmatScore }}</li>\n<li>Overall GWA: {{ $(\"Check Admission Requirements\").item.json.overallGWA }}</li>\n<li>Science/Math GWA: {{ $(\"Check Admission Requirements\").item.json.scienceMathGWA }}</li>\n</ul>\n\n<p><strong>Interview Schedule:</strong></p>\n<p>Date & Time: {{ $now.plus(7, \"days\").toFormat(\"MMMM d, yyyy\") }} at 9:00 AM</p>\n<p>Location: USTP College of Medicine, Cagayan de Oro City</p>\n<p>A calendar invitation has been sent to your email.</p>\n\n<p>Please confirm your attendance by replying to this email.</p>\n\n<p>Best regards,<br>USTP College of Medicine Admissions Office</p>","options":{}},"id":"7083a736-5369-4896-8f73-49ce58a2af70","name":"Send Interview Invitation","type":"n8n-nodes-base.gmail","typeVersion":2.2,"position":[2480,304],"webhookId":"4760496a-af83-42af-acdd-1764d3badc28"},
    {"parameters":{"sendTo":"={{ $json.email }}","subject":"USTP College of Medicine - Application Status","message":"=Dear {{ $json.fullName }},\n\n<p>Thank you for your interest in the USTP College of Medicine.</p>\n\n<p>After careful review of your application, we regret to inform you that we are unable to offer you admission at this time.</p>\n\n<p><strong>Your Application Summary:</strong></p>\n<ul>\n<li>NMAT Score: {{ $json.nmatScore }} (Required: 85)</li>\n<li>Overall GWA: {{ $json.overallGWA }} (Required: 85)</li>\n<li>Science/Math GWA: {{ $json.scienceMathGWA }} (Required: 85)</li>\n</ul>\n\n<p>We encourage you to continue pursuing your academic goals and consider reapplying in the future.</p>\n\n<p>Best regards,<br>USTP College of Medicine Admissions Office</p>","options":{}},"id":"f7c930ca-2888-48b1-9a34-4730b439415f","name":"Send Rejection Letter","type":"n8n-nodes-base.gmail","typeVersion":2.2,"position":[2032,496],"webhookId":"aba9ddf6-264e-4b07-9d77-bd720f3f7a97"},
